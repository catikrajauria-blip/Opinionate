rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && 
             ((request.auth.token.keys().hasAll(['email']) && request.auth.token.email.lower() == 'catikrajauria@gmail.com') ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    function isBlocked() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == true;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isValidId(id) {
       return id is string && id.size() <= 256;
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidBlog(incoming());
      allow update: if (isAdmin() && isValidBlog(incoming())) || (isSignedIn() && !isBlocked() && isOnlyStatUpdate());
      allow delete: if isAdmin();

      function isValidBlog(data) {
        return data.title is string && data.title.size() <= 800 &&
               data.slug is string && data.slug.size() <= 800 &&
               data.summary is string && data.summary.size() <= 8000 &&
               data.content is string && data.content.size() <= 300000;
      }

      function isOnlyStatUpdate() {
        // Allows public (and admins) to update only these specific numeric stats
        return incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'viewsCount', 'ratingAverage', 'ratingCount']);
      }
    }

    // Comments (including collection groups)
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }

    match /blogs/{blogId}/comments/{commentId} {
      allow read: if true;
      allow create: if isValidComment(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();

      function isValidComment(data) {
        return data.name is string && data.name.size() <= 60 &&
               data.content is string && data.content.size() <= 2000 &&
               data.blogId == blogId;
      }
    }

    // Subscribers
    match /subscribers/{email} {
      allow read: if isAdmin();
      allow create, update: if (incoming().email == email && incoming().status == 'active') || isAdmin();
      allow delete: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidMessage(incoming());

      function isValidMessage(data) {
        return data.name is string && data.email is string && data.message is string && data.message.size() <= 5000;
      }
    }

    // Ratings/Likes/Views
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if (isSignedIn() && !isBlocked() && (incoming().score >= 1 && incoming().score <= 5)) || isAdmin();
    }
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn() && !isBlocked();
    }
    match /views/{viewId} {
      allow read: if true;
      allow write: if true; // Views can stay public for now as they use specific ID logic
    }

    // Users & Activity
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if (isOwner(uid) && isValidUserUpdate(incoming(), existing()) && !isBlocked()) || isAdmin();
      allow delete: if isAdmin();

      function isValidUser(data) {
        return data.uid == uid && data.role == 'user' && data.isBlocked == false;
      }
      function isValidUserUpdate(curr, prev) {
         // User cannot change their own role or blocked status
         return curr.role == prev.role && curr.isBlocked == prev.isBlocked;
      }

      match /saved_blogs/{blogId} {
        allow read, write: if isOwner(uid) && !isBlocked();
      }
    }

    // Curated News
    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNews(incoming());
      allow update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();

      function isValidNews(data) {
        return data.title is string && data.title.size() <= 300 &&
               data.url is string && 
               data.summary is string && data.summary.size() <= 3000 &&
               data.category is string;
      }
    }
  }
}
