rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Global admin check (using email as primary, DB as secondary)
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().hasAll(['email']) && 
         request.auth.token.email.lower() == 'catikrajauria@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Generic blocked check - for non-user-document paths
    function isBlocked() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
       return id is string && id.size() >= 1 && id.size() <= 128;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Support for CollectionGroup queries (dashboard data)
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
    match /{path=**}/ratings/{ratingId} {
      allow read: if true;
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidBlog(incoming());
      allow update: if (isAdmin() && isValidBlog(incoming())) || 
                      (isOnlyStatUpdate() && (!isSignedIn() || !isBlocked()));
      allow delete: if isAdmin();

      function isValidBlog(data) {
        return data.title is string && data.title.size() <= 2000 &&
               data.slug is string && data.slug.size() <= 1000 &&
               (data.summary is string && data.summary.size() <= 20000) &&
               (data.content is string && data.content.size() <= 1000000);
      }

      function isOnlyStatUpdate() {
        let allowedFields = ['viewsCount', 'ratingAverage', 'ratingCount', 'likesCount'];
        return incoming().diff(existing()).affectedKeys().hasOnly(allowedFields);
      }
    }

    // Comments
    match /blogs/{blogId}/comments/{commentId} {
      allow create: if isValidComment(incoming());
      allow update, delete: if isAdmin();

      function isValidComment(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.content is string && data.content.size() <= 10000 &&
               data.blogId == blogId;
      }
    }

    // Subscribers
    match /subscribers/{email} {
      allow read: if isAdmin();
      allow create, update: if (incoming().email == email && incoming().status == 'active') || isAdmin();
      allow delete: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidMessage(incoming());

      function isValidMessage(data) {
        return data.name is string && data.email is string && 
               data.message is string && data.message.size() <= 20000;
      }
    }

    // Interaction Data
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if (isAdmin()) || (!isBlocked() && incoming().score >= 1 && incoming().score <= 5);
    }
    match /likes/{likeId} {
      allow read: if true;
      allow write: if (isAdmin()) || (!isBlocked() && isValidId(incoming().userId));
    }
    match /views/{viewId} {
      allow read, write: if true;
    }

    // Users & Personal Data
    match /users/{uid} {
      // Use resource.data for self-checks to avoid recursive get()
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if isAdmin() || (
        isOwner(uid) && 
        isValidUserUpdate(incoming(), existing()) && 
        existing().isBlocked == false
      );
      allow delete: if isAdmin();

      function isValidUser(data) {
        let isDefaultAdmin = data.email.lower() == 'catikrajauria@gmail.com';
        let allowedRole = isDefaultAdmin ? 'admin' : 'user';
        return data.uid == uid && data.role == allowedRole && data.isBlocked == false;
      }
      function isValidUserUpdate(curr, prev) {
         // Standard check: user cannot change their own role or blocked status
         // Except we allow the hardcoded admin to keep their status
         let isDefaultAdmin = curr.email.lower() == 'catikrajauria@gmail.com';
         return isDefaultAdmin || (curr.role == prev.role && curr.isBlocked == prev.isBlocked);
      }

      match /saved_blogs/{blogId} {
        allow read, write: if isOwner(uid) && (isAdmin() || get(/databases/$(database)/documents/users/$(uid)).data.isBlocked == false);
      }
    }

    // Curated News
    match /news/{newsId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && !isBlocked() && isOnlyNewsStatUpdate());

      function isValidNews(data) {
        return data.title is string && data.title.size() <= 1000 &&
               data.url is string && 
               data.summary is string && data.summary.size() <= 10000 &&
               data.category is string;
      }

      function isOnlyNewsStatUpdate() {
        let allowedFields = ['likesCount', 'dislikesCount'];
        return incoming().diff(existing()).affectedKeys().hasOnly(allowedFields);
      }

      match /interactions/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) && !isBlocked();
      }
    }

    // Newspapers
    match /newspapers/{newspaperId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isOnlyNewspaperStatUpdate() && (!isSignedIn() || !isBlocked()));

      function isValidNewspaper(data) {
        return data.title is string && data.title.size() <= 1000 &&
               data.content is string && data.content.size() <= 2000000;
      }

      function isOnlyNewspaperStatUpdate() {
        let allowedFields = ['readCount', 'downloadCount'];
        return incoming().diff(existing()).affectedKeys().hasOnly(allowedFields);
      }
    }

    // System Stats
    match /system_stats/{docId} {
      allow read, write: if true;
    }
  }
}
